# ── Supabase (client-side — safe to expose) ──────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Supabase (server-side only — NEVER expose to client) ─────────────────────
# Used exclusively by /api/parse-timetable (Vercel serverless function).
# Add to: Vercel Dashboard → Settings → Environment Variables
# Add to: GitHub → Repo Settings → Secrets (for Actions cron)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: override Supabase URL in server context (defaults to VITE_SUPABASE_URL)
# SUPABASE_URL=https://your-project-id.supabase.co
